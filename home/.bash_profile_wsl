# ~/.bash_profile
#
# Author Augusto Pascutti <augusto.hp@gmail.com>
# Part of http://github.com/augustohp/warwick
# vim: ft=sh:

warwick_verbose "Loading ~/.bash_profile_wsl ..."

WIN_HOME_RAW="$(cmd.exe /c "<nul set /p=%UserProfile%" 2>/dev/null)"
if [ -z "$WIN_HOME_RAW" ]
then
	echo "Error: /mnt/c not available." >&2
	echo "Try: ">&2
	echo "  PS$ wsl.exe --shutdown"
	return 1
fi

export WSL_HOME="$(wslpath $WIN_HOME_RAW)"

export WSL_DIR_DOWNLOADS="${HOME}/Downloads"
if [ ! -d "$WSL_DIR_DOWNLOADS" ]
then
	warwick_verbose_inside "Linking Downloads folder to $HOME"
	ln -s "${WSL_HOME}/Downloads" "${WSL_DIR_DOWNLOADS}"
fi

export WSL_DIR_DESKTOP="${HOME}/Desktop"
if [ ! -d "$WSL_DIR_DESKTOP" ]
then
	warwick_verbose_inside "Linking Desktop folder to $HOME"
	ln -s "${WSL_HOME}/Desktop" "${WSL_DIR_DESKTOP}"
fi

export WSL_DIR_SRC="${HOME}/src"
if [ ! -d "${WSL_DIR_SRC}" ]
then
	source_path="${WSL_HOME}/src"
	if [ ! -d "${source_path}" ]
	then
		mkdir "${source_path}"
	fi
	warwick_verbose_inside "Linking 'src' folder to $HOME"
	ln -s "${source_path}" "${WSL_DIR_SRC}"
fi

#------------------------------------------------------------------------------
#                                                                       Aliases
#

alias ls="ls -GhcS --color=auto"

# -----------------------------------------------------------------------------
#                                                                        NeoVim
#
# NeoVim for WSL is more easily installed on a custom directory, using pre-built
# binaries. This makes sure that directory is on our PATH.

neovim_dir="/opt/nvim-linux-x86_64"
if [ -d "$neovim_dir" ]
then
	warwick_verbose_inside "Neovim"
	export PATH="$neovim_dir/bin:$PATH"
fi

# -----------------------------------------------------------------------------
#                                                                      X Server
# 
warwick_verbose_inside "X-server (X410) config"
export DISPLAY="$(ip route | grep default | awk '{print $3; exit;}'):0.0"
export LIBGL_ALWAYS_INDIRECT=1
export GDK_SCALE=1
